class Circle:
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        print(f"Circle area: {3.14 * self.radius * self.radius}")

class Rectangle:
    def __init__(self, length, width):
        self.length = length
        self.width = width

    def area(self):
        print(f"Rectangle area: {self.length * self.width}")

class Triangle:
    def __init__(self, base, height):
        self.base = base
        self.height = height

    def area(self):
        print(f"Triangle area: {0.5 * self.base * self.height}")

c1 = Circle(5)
c1.area()

r1 = Rectangle(4, 6)
r1.area()

t1 = Triangle(3, 8)
t1.area()